# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite:///./deal_intelligence.db

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Vector Store (faiss or pinecone)
VECTOR_STORE_TYPE=faiss
PINECONE_API_KEY=your-pinecone-api-key-here

# ML Model Directory
ML_MODEL_DIR=./models/saved

# Llama Model Path (for local lightweight tasks)
LLAMA_MODEL_PATH=/path/to/llama/model
